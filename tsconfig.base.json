{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@heyhorizon/security": ["packages/security/src"],
      "@heyhorizon/contracts": ["packages/contracts/src"],
      "@heyhorizon/config": ["packages/config/src"],
      "@heyhorizon/utils": ["packages/utils/src"]
    }
  }
}
